<?xml version="1.0" encoding="UTF-8"?>
<style xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="style.xsd">

  <!-- White Background -->
  <background>070707</background>

  <!-- Land Areas -->
  <layer>
    <name>LNDARE</name>
    <style>
      <fill_color>0D0A08</fill_color>
      <line_color>0E0F15</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Shoreline Construction -->
  <layer>
    <name>SLCONS</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>141616</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Contours -->
  <layer>
    <name>DEPCNT</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>0C0D0E</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
  </layer>

  <!-- Depth Soundings -->
  <layer>
    <name>SOUNDG</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>000</line_color>
      <line_width>0</line_width>
      <marker_size>0</marker_size>
    </style>
  </layer>

</style>

