<?xml version="1.0" encoding="UTF-8"?>
<style xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="style.xsd">

  <!-- White Background -->
  <background>070707</background>

  <!-- Land Areas -->
  <layer>
    <name>LNDARE</name>
    <style>
      <fill_color>2C291B</fill_color>
      <line_color>252A2B</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Areas -->
  <layer>
    <name>DEPARE</name>
    <style>
      <fill_color>070707</fill_color>
      <line_color>888</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
    <cutoff_attr>DRVAL1</cutoff_attr>
    <cutoff>
      <value>0</value>
      <style>
        <fill_color>15251f</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>2</value>
      <style>
        <fill_color>16232f</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>5</value>
      <style>
        <fill_color>151b21</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>10</value>
      <style>
        <fill_color>0c0e0f</fill_color>
      </style>
    </cutoff>
  </layer>

  <!-- Lake Areas -->
  <layer>
    <name>LAKARE</name>
    <style>
      <fill_color>16232f</fill_color>
      <line_color>888</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
  </layer>

  <!-- Shoreline Construction -->
  <layer>
    <name>SLCONS</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>232C34</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Contours -->
  <layer>
    <name>DEPCNT</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>1A252F</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
  </layer>

  <!-- Depth Soundings -->
  <layer>
    <name>SOUNDG</name>
    <style>
      <text_color>474e4f</text_color>
      <text_font>monospace</text_font>
      <text_size>12</text_size>
    </style>
  </layer>

</style>

