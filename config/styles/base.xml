<?xml version="1.0" encoding="UTF-8"?>
<style xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="style.xsd">

  <!-- White Background -->
  <background>@CHWHT</background>

  <!-- Land Areas -->
  <layer>
    <name>LNDARE</name>
    <style>
      <fill_color>@LANDA</fill_color>
      <line_color>@CHBLK</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Areas -->
  <layer>
    <name>DEPARE</name>
    <style>
      <fill_color>@DEPDW</fill_color>
      <line_color>@CHBLK</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
    <cutoff_attr>DRVAL1</cutoff_attr>
    <cutoff>
      <value>0</value>
      <style>
        <fill_color>@DEPIT</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>2</value>
      <style>
        <fill_color>@DEPVS</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>5</value>
      <style>
        <fill_color>@DEPMS</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>10</value>
      <style>
        <fill_color>@DEPMD</fill_color>
      </style>
    </cutoff>
  </layer>

  <!-- Dredged Areas -->
  <layer>
    <name>DRGARE</name>
    <style>
      <fill_color>@DEPDW</fill_color>
      <line_color>@CHBLK</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
    <cutoff_attr>DRVAL2</cutoff_attr>
    <cutoff>
      <value>0</value>
      <style>
        <fill_color>@DEPIT</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>2</value>
      <style>
        <fill_color>@DEPVS</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>5</value>
      <style>
        <fill_color>@DEPMS</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>10</value>
      <style>
        <fill_color>@DEPMD</fill_color>
      </style>
    </cutoff>
  </layer>

  <!-- Lake Areas -->
  <layer>
    <name>LAKARE</name>
    <style>
      <fill_color>@DEPVS</fill_color>
      <line_color>@CHBLK</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
  </layer>

  <!-- Shoreline Construction -->
  <layer>
    <name>SLCONS</name>
    <style>
      <fill_color>@LANDA</fill_color>
      <line_color>@CHBLK</line_color>
      <line_width>2</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Contours -->
  <layer>
    <name>DEPCNT</name>
    <style>
      <line_color>@CHBLK</line_color>
      <line_width>1</line_width>
    </style>
  </layer>

  <!-- Depth Soundings -->
  <layer>
    <name>SOUNDG</name>
    <style>
      <text_color>@CHBLK</text_color>
      <text_font>monospace</text_font>
      <text_size>12</text_size>
    </style>
  </layer>

</style>
