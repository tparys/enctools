<?xml version="1.0" encoding="UTF-8"?>
<style xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="style.xsd">

  <!-- White Background -->
  <background>fff</background>

  <!-- Land Areas -->
  <layer>
    <layer_name>LNDARE</layer_name>
    <fill_color>C8B87A</fill_color>
    <line_color>A8ACA1</line_color>
    <line_width>1</line_width>
    <marker_size>5</marker_size>
  </layer>

  <!-- Shoreline Construction -->
  <layer>
    <layer_name>SLCONS</layer_name>
    <fill_color>000</fill_color>
    <line_color>989C92</line_color>
    <line_width>1</line_width>
    <marker_size>5</marker_size>
  </layer>

  <!-- Depth Contours -->
  <layer>
    <layer_name>DEPCNT</layer_name>
    <fill_color>000</fill_color>
    <line_color>B2CBD6</line_color>
    <line_width>1</line_width>
    <marker_size>0</marker_size>
  </layer>

  <!-- Obstructions -->
  <layer>
    <layer_name>OBSTRN</layer_name>
    <fill_color>f88</fill_color>
    <line_color>f88</line_color>
    <line_width>1</line_width>
    <marker_size>5</marker_size>
  </layer>

  <!-- Depth Soundings -->
  <layer>
    <layer_name>SOUNDG</layer_name>
    <fill_color>000</fill_color>
    <line_color>000</line_color>
    <line_width>0</line_width>
    <marker_size>0</marker_size>
  </layer>

  <!-- Bouys (Lateral) -->
  <layer>
    <layer_name>BOYLAT</layer_name>
    <fill_color>0f0</fill_color>
    <line_color>0f0</line_color>
    <line_width>0</line_width>
    <marker_size>5</marker_size>
  </layer>

  <!-- Wrecks -->
  <layer>
    <layer_name>WRECKS</layer_name>
    <fill_color>f00</fill_color>
    <line_color>f00</line_color>
    <line_width>0</line_width>
    <marker_size>5</marker_size>
  </layer>

</style>

