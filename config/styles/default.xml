<?xml version="1.0" encoding="UTF-8"?>
<style xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="style.xsd">

  <!-- White Background -->
  <background>d3e9ed</background>

  <!-- Land Areas -->
  <layer>
    <name>LNDARE</name>
    <style>
      <fill_color>C8B87A</fill_color>
      <line_color>A8ACA1</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Areas -->
  <layer>
    <name>DEPARE</name>
    <style>
      <fill_color>d3e9ed</fill_color>
      <line_color>888</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
    <cutoff_attr>DRVAL1</cutoff_attr>
    <cutoff>
      <value>0</value>
      <style>
        <fill_color>82b194</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>2</value>
      <style>
        <fill_color>73b5ee</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>5</value>
      <style>
        <fill_color>97c4f1</fill_color>
      </style>
    </cutoff>
    <cutoff>
      <value>10</value>
      <style>
        <fill_color>b9d4e0</fill_color>
      </style>
    </cutoff>
  </layer>

  <!-- Shoreline Construction -->
  <layer>
    <name>SLCONS</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>989C92</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Contours -->
  <layer>
    <name>DEPCNT</name>
    <style>
      <fill_color>000</fill_color>
      <line_color>888</line_color>
      <line_width>1</line_width>
      <marker_size>0</marker_size>
    </style>
  </layer>

  <!-- Obstructions -->
  <layer>
    <name>OBSTRN</name>
    <style>
      <fill_color>f88</fill_color>
      <line_color>f88</line_color>
      <line_width>1</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Depth Soundings -->
  <layer>
    <name>SOUNDG</name>
    <style>
      <text_color>444</text_color>
      <text_font>monospace</text_font>
      <text_size>12</text_size>
    </style>
  </layer>

  <!-- Bouys (Lateral) -->
  <layer>
    <name>BOYLAT</name>
    <style>
      <fill_color>ffa500</fill_color>
      <line_color>ffa500</line_color>
      <line_width>0</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

  <!-- Wrecks -->
  <layer>
    <name>WRECKS</name>
    <style>
      <fill_color>f00</fill_color>
      <line_color>f00</line_color>
      <line_width>0</line_width>
      <marker_size>5</marker_size>
    </style>
  </layer>

</style>

